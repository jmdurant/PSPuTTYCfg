<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PuTTYProfileManager.Avalonia.Views.PasswordDialog"
        Title="Password"
        Width="420" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

    <Grid RowDefinitions="Auto,Auto,Auto" Margin="20">

        <TextBlock Grid.Row="0" x:Name="PromptText"
                   Foreground="{StaticResource TextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <TextBox Grid.Row="1" x:Name="PasswordInput"
                 PasswordChar="&#x25CF;"
                 Watermark="Enter password..."
                 Margin="0,0,0,16" />

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="SkipButton" Content="Skip"
                    Click="OnSkip" Width="80" />
            <Button Content="OK" Click="OnOk" Width="80"
                    Background="{StaticResource AccentBrush}"
                    Foreground="#1B2838" />
            <Button Content="Cancel" Click="OnCancel" Width="80" />
        </StackPanel>

    </Grid>
</Window>
