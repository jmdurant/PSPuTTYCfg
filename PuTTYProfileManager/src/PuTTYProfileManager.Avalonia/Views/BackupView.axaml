<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PuTTYProfileManager.Avalonia.ViewModels"
             xmlns:models="using:PuTTYProfileManager.Avalonia.Models"
             xmlns:views="using:PuTTYProfileManager.Avalonia.Views"
             x:Class="PuTTYProfileManager.Avalonia.Views.BackupView"
             x:DataType="vm:BackupViewModel">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Margin="12">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Refresh Sessions" Command="{Binding RefreshCommand}" />
            <Button Content="Select All" Command="{Binding SelectAllCommand}" />
            <Button Content="Deselect All" Command="{Binding DeselectAllCommand}" />
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="{Binding SelectedCount}" />
                <Run Text=" of " />
                <Run Text="{Binding TotalCount}" />
                <Run Text=" selected" />
            </TextBlock>
        </StackPanel>

        <!-- Sessions DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Sessions}"
                  SelectedItem="{Binding SelectedSession}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="{StaticResource BorderBrush}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:SelectableSession">
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Session Name"
                                    Binding="{Binding Session.DisplayName}"
                                    Width="*"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Connection"
                                    Binding="{Binding Session.Summary}"
                                    Width="200"
                                    IsReadOnly="True" />
                <DataGridTextColumn Header="Settings"
                                    Binding="{Binding Session.Values.Count}"
                                    Width="80"
                                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Linked Files Panel -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                CornerRadius="6" Padding="12" Margin="0,8,0,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <CheckBox Content="Include linked files (PPK keys, certificates, etc.)"
                              IsChecked="{Binding IncludeLinkedFiles}"
                              Foreground="{StaticResource TextBrush}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12">
                        <Run Text="{Binding LinkedFileCount}" />
                        <Run Text=" file(s) found" />
                    </TextBlock>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding LinkedFiles}"
                              IsVisible="{Binding IncludeLinkedFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,2">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SettingLabel}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" Width="120" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding OriginalPath}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding DisplaySize}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" Width="60"
                                           TextAlignment="Right"
                                           Margin="4,0" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Exists, Converter={x:Static views:ExistsToTextConverter.Instance}}"
                                           Foreground="{Binding Exists, Converter={x:Static views:ExistsToColorConverter.Instance}}"
                                           FontSize="12" Width="60"
                                           TextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Session Details -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}"
                CornerRadius="6" Padding="12" Margin="0,8,0,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                IsVisible="{Binding SelectedSession, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel Spacing="4">
                <TextBlock Text="Session Details" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" FontSize="13" />
                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="12">
                    <Run Text="Name: " FontWeight="SemiBold" />
                    <Run Text="{Binding SelectedSession.Session.DisplayName}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="12">
                    <Run Text="Connection: " FontWeight="SemiBold" />
                    <Run Text="{Binding SelectedSession.Session.Summary}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    <Run Text="{Binding SelectedSession.Session.Values.Count}" />
                    <Run Text=" registry settings" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Backup Button -->
        <Button Grid.Row="4" Content="Backup Selected Sessions"
                Command="{Binding BackupSelectedCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="0,12,0,0" Padding="12,10"
                FontWeight="Bold"
                Background="{StaticResource AccentBrush}"
                Foreground="#1B2838" />

    </Grid>
</UserControl>
