<Window x:Class="PuTTYProfileManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PuTTYProfileManager.Views"
        Title="PuTTY Profile Manager"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PuTTY Profile Manager"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="20" FontWeight="Bold" />
                </StackPanel>
                <TextBlock Text="Backup &amp; Restore PuTTY Sessions"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1" Margin="0,4,0,0">
            <TabItem Header="BACKUP">
                <views:BackupView DataContext="{Binding Backup}" />
            </TabItem>
            <TabItem Header="RESTORE">
                <views:RestoreView DataContext="{Binding Restore}" />
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource PrimaryBrush}" Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </Border>
    </Grid>
</Window>
