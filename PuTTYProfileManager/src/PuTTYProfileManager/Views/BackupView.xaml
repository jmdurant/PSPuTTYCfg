<UserControl x:Class="PuTTYProfileManager.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Refresh Sessions"
                            Style="{StaticResource ModernButton}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Select All"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectAllCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Deselect All"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeselectAllCommand}" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                    <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                    <Run Text=" of " />
                    <Run Text="{Binding TotalCount, Mode=OneWay}" />
                    <Run Text=" selected" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- Session List -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="2">
            <DataGrid ItemsSource="{Binding Sessions}"
                      SelectedItem="{Binding SelectedSession}"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Session Name" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="Connection" Binding="{Binding Summary}" Width="*" />
                    <DataGridTextColumn Header="Settings" Binding="{Binding SettingsCount}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Linked Files Panel -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="6"
                Padding="12" Margin="0,12,0,0">
            <StackPanel>
                <Grid>
                    <CheckBox Content="Include linked files (PPK keys, certificates, etc.)"
                              IsChecked="{Binding IncludeLinkedFiles}"
                              FontSize="13" FontWeight="SemiBold"
                              Foreground="{StaticResource AccentBrush}" />
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding LinkedFileCount, Mode=OneWay}" />
                        <Run Text=" file(s) found" />
                    </TextBlock>
                </Grid>

                <!-- File list (shown when there are files) -->
                <ItemsControl ItemsSource="{Binding LinkedFiles}" Margin="0,8,0,0"
                              Visibility="{Binding IncludeLinkedFiles, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding SettingLabel}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" Width="120" />
                                <TextBlock Grid.Column="1" Text="{Binding OriginalPath}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis"
                                           Margin="8,0" />
                                <TextBlock Grid.Column="2" Text="{Binding DisplaySize}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12" Width="60" TextAlignment="Right" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="3" FontSize="12" Width="60">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                            <Setter Property="Text" Value="Found" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Exists}" Value="False">
                                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    <Setter Property="Text" Value="Missing" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Session Detail Preview -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="6"
                Padding="12" Margin="0,12,0,0" Height="100"
                Visibility="{Binding SelectedSession, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel>
                <TextBlock Text="Session Details" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8" />
                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13">
                    <Run Text="Name: " FontWeight="SemiBold" />
                    <Run Text="{Binding SelectedSession.DisplayName, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13">
                    <Run Text="Connection: " FontWeight="SemiBold" />
                    <Run Text="{Binding SelectedSession.Summary, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0">
                    <Run Text="{Binding SelectedSession.SettingsCount, Mode=OneWay}" />
                    <Run Text=" registry values" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Backup Button -->
        <Border Grid.Row="4" Margin="0,12,0,0">
            <Button Content="Backup Selected Sessions"
                    Style="{StaticResource ModernButton}"
                    Command="{Binding BackupSelectedCommand}"
                    FontSize="15"
                    Padding="24,12"
                    HorizontalAlignment="Stretch" />
        </Border>
    </Grid>
</UserControl>
