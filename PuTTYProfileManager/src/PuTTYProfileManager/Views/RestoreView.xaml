<UserControl x:Class="PuTTYProfileManager.Views.RestoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Archive Selection -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ArchivePath, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ArchivePath}" Value="{x:Null}">
                                    <Setter Property="Text" Value="No archive selected..." />
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Column="1"
                        Content="Browse..."
                        Style="{StaticResource ModernButton}"
                        Command="{Binding BrowseArchiveCommand}" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,12"
                Visibility="{Binding ArchivePath, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Select All"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectAllCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Deselect All"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DeselectAllCommand}" />
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="13">
                    <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                    <Run Text=" of " />
                    <Run Text="{Binding TotalCount, Mode=OneWay}" />
                    <Run Text=" selected" />
                </TextBlock>
            </Grid>
        </Border>

        <!-- Session List -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="2">
            <DataGrid ItemsSource="{Binding ArchivedSessions}"
                      SelectedItem="{Binding SelectedSession}"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Session Name" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="Connection" Binding="{Binding Summary}" Width="*" />
                    <DataGridTextColumn Header="Settings" Binding="{Binding SettingsCount}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Session Detail Preview -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="6"
                Padding="12" Margin="0,12,0,0" Height="120"
                Visibility="{Binding SelectedSession, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
            <StackPanel>
                <TextBlock Text="Session Details" FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8" />
                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13">
                    <Run Text="Name: " FontWeight="SemiBold" />
                    <Run Text="{Binding SelectedSession.DisplayName, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13">
                    <Run Text="Connection: " FontWeight="SemiBold" />
                    <Run Text="{Binding SelectedSession.Summary, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0">
                    <Run Text="{Binding SelectedSession.SettingsCount, Mode=OneWay}" />
                    <Run Text=" registry values" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Restore Button -->
        <Border Grid.Row="4" Margin="0,12,0,0">
            <Button Content="Restore Selected Sessions"
                    Style="{StaticResource DangerButton}"
                    Command="{Binding RestoreSelectedCommand}"
                    FontSize="15"
                    Padding="24,12"
                    HorizontalAlignment="Stretch" />
        </Border>
    </Grid>
</UserControl>
